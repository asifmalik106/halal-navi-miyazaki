# Copy this file to .env and fill in the values. Never commit .env.
#
# Run the build with:  node --env-file=.env build.js
# (or: node build.js  — build.js also parses .env on its own as a fallback)

# OpenRouteService API key (raw key, no "Bearer" prefix).
# Get one free at https://openrouteservice.org/dev/#/signup (no credit card).
ORS_API_KEY=

# GitHub personal access token with ONLY the "gist" scope.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# The ID of the PUBLIC Gist that holds data.json.
# It's the hash in the Gist URL: https://gist.github.com/<user>/<GIST_ID>
GIST_ID=
